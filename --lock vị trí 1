-- 🌸 Auto TP1 Lock 3 Giai Đoạn (Mốc thời gian tuyệt đối)

local Players = game:GetService("Players")
local p = Players.LocalPlayer or Players.PlayerAdded:Wait()
local STATE = { tp1 = false }

-- 🔒 Giới hạn tài khoản
if p.Name ~= "ulucasko" then
	warn("[AUTO] 🚫 Acc không được phép chạy TP1 Lock.")
	return
end

-- ⏳ Chờ character và HumanoidRootPart sẵn sàng
local function waitForHRP()
	local chr = p.Character or p.CharacterAdded:Wait()
	local hrp = chr:FindFirstChild("HumanoidRootPart")
	local waited = 0
	while not hrp and waited < 5 do
		task.wait(0.2)
		waited += 0.2
		chr = p.Character or p.CharacterAdded:Wait()
		hrp = chr:FindFirstChild("HumanoidRootPart")
	end
	return hrp
end

-- 🔒 Hàm bắt đầu lock vị trí
local function startLock(pos)
	if STATE.tp1 then return end
	STATE.tp1 = true
	print("[AUTO] 🔒 Bắt đầu lock vị trí tại:", tostring(pos))

	local hrp = waitForHRP()
	local look
	if hrp then
		pcall(function()
			look = hrp.CFrame.LookVector
		end)
	end

	task.spawn(function()
		while STATE.tp1 do
			task.wait()
			local c = p.Character
			if c then
				local h = c:FindFirstChild("HumanoidRootPart")
				if h then
					pcall(function()
						h.Velocity = Vector3.new(0, 0, 0)
						if look then
							h.CFrame = CFrame.new(pos, pos + look)
						else
							h.CFrame = CFrame.new(pos)
						end
					end)
				end
			end
		end
	end)
end

-- 🔓 Hàm dừng lock
local function stopLock()
	if STATE.tp1 then
		STATE.tp1 = false
		print("[AUTO] 🔓 Dừng lock vị trí.")
	end
end

-- 🕒 Chuỗi theo mốc thời gian tuyệt đối
task.spawn(function()
	local pos = Vector3.new(40, 3.63, -130.14)

	local timeline = {
		{9,   "start"},
		{63,  "stop"},
		{75,  "start"},
		{129, "stop"},
		{141, "start"},
		{200, "stop"},
	}

	print("[AUTO] ⏳ Bắt đầu chuỗi TP1 Lock...")

	local last = 0
	for _, step in ipairs(timeline) do
		local t, action = step[1], step[2]
		task.wait(t - last)
		last = t

		if action == "start" then
			startLock(pos)
			print("[AUTO] ▶ TP1 Lock tại " .. t .. "s")
		else
			stopLock()
			print("[AUTO] ⏹ Stop TP1 Lock tại " .. t .. "s")
		end
	end

	print("[AUTO] ✅ Hoàn tất 3 giai đoạn TP1 Lock.")
end)
